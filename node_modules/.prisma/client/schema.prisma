generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Grade {
  A
  B
  C
  D
}

enum TradeAction {
  BUY
  SELL
}

model User {
  id                  Int      @id @default(autoincrement())
  telegramId          String   @unique
  username            String?
  alertsEnabled       Boolean  @default(false)
  paperTrading        Boolean  @default(true) // Paper trading enabled by default
  encryptedPrivateKey String? // For copy trading later
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Wallet {
  id           Int       @id @default(autoincrement())
  address      String    @unique
  grade        Grade?
  roi          Decimal?
  winRate      Decimal?
  lastAnalyzed DateTime?
  isBot        Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  trades Trade[]
}

model Market {
  id          Int      @id @default(autoincrement())
  conditionId String   @unique // Polymarket condition ID
  question    String
  description String?
  outcomes    String[] // e.g., ["Yes", "No"]
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trades Trade[]
}

model Trade {
  id              Int         @id @default(autoincrement())
  walletId        Int
  wallet          Wallet      @relation(fields: [walletId], references: [id])
  marketId        Int
  market          Market      @relation(fields: [marketId], references: [id])
  outcomeIndex    Int // 0 for "Yes", 1 for "No"
  action          TradeAction
  price           Decimal // Price when bought
  shares          Decimal // Number of shares bought
  timestamp       DateTime    @default(now())
  transactionHash String?     @unique // Optional: store the original tx hash

  @@index([walletId])
  @@index([marketId])
}
